# Browser requests use the Next.js proxy to avoid CORS issues.
NEXT_PUBLIC_API_BASE_URL=/api/proxy

# Server-side URL used by the proxy route.
API_BASE_URL=http://localhost:8000

# Set to "true" to use the built-in mock data instead of calling the backend.
# Useful for building/demoing the frontend before the backend is ready.
NEXT_PUBLIC_USE_MOCK_API=false
